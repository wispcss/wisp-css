{
  "name": "wisp-css",
  "version": "1.0.0",
  "description": "A spirited, modular, and lightweight CSS framework that's barely there.",
  "keywords": [
    "css",
    "framework",
    "modular",
    "cascade",
    "css-layers",
    "semantic",
    "objects",
    "components",
    "utilities",
    "responsive",
    "no-build",
    "lightweight"
  ],
  "license": "MIT",
  "author": "Eric Harms",
  "scripts": {
    "build": "esbuild src/imports.css --bundle --minify --outfile=dist/wisp.min.css",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  },
  "dependencies": {
    "vitepress": "^1.6.4"
  }
}